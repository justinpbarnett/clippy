{
  "name": "clipjar",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:chrome",
    "build:chrome": "vite build",
    "build:firefox": "vite build --config vite.config.firefox.ts",
    "preview": "vite preview",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "zip": "npm run zip:chrome",
    "zip:chrome": "cd dist-chrome && zip -r ../clipjar-chrome-$npm_package_version.zip .",
    "zip:firefox": "cd dist-firefox && zip -r ../clipjar-firefox-$npm_package_version.zip .",
    "screenshots": "node tests/store-screenshots.mjs",
    "gen-icons": "node scripts/gen-icons.mjs"
  },
  "dependencies": {
    "fuzzysort": "^3.1.0",
    "idb": "^8.0.1"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.30",
    "@samrum/vite-plugin-web-extension": "^5.1.1",
    "@types/chrome": "^0.0.304",
    "autoprefixer": "^10.4.21",
    "playwright": "^1.59.1",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^5.4.14",
    "vitest": "^2.1.8"
  }
}
